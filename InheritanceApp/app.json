{
  "expo": {
    "name": "حاسبة المواريث الإسلامية",
    "slug": "merath_mobile",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inheritance.calculator",
      "buildNumber": "5.0.0"
    },
    "android": {
      "package": "com.inheritance.calculator",
      "versionCode": 500,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "permissions": [
        "android.permission.INTERNET"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-file-system",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "expo-system-ui",
      "expo-localization",
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "2c2de43d-16e9-4c3f-88b6-be678d534494"
      }
    }
  }
}
